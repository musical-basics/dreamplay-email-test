{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "input": {
    "maxFileSize": 52428800
  },
  "output": {
    "filePath": "../dreamplay-email-repomix.xml",
    "style": "xml",
    "parsableStyle": false,
    "fileSummary": true,
    "directoryStructure": true,
    "files": true,
    "removeComments": false,
    "removeEmptyLines": false,
    "compress": false,
    "topFilesLength": 5,
    "showLineNumbers": false,
    "truncateBase64": false,
    "copyToClipboard": false,
    "includeFullDirectoryStructure": false,
    "tokenCountTree": false,
    "git": {
      "sortByChanges": true,
      "sortByChangesMaxCommits": 100,
      "includeDiffs": false,
      "includeLogs": false,
      "includeLogsCount": 50
    }
  },
  "include": [],
  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "_legacy_v0_code/**",
      "**/*.local",
      "*repomix*",
      "components/ui/**",
      "scripts/**",
      "supabase/**",
      "hooks/**",
      "inngest/**",
      "_inngest_lessons.md",
      "all_campaigns.json",
      "campaign_record.json",
      "campaign_updated.json",
      "recent_files.json",
      "postcss.config.mjs",
      "tsconfig.json",
      "tsconfig.tsbuildinfo",
      "next-env.d.ts",
      "tailwind.config.*",
      "components/dnd-editor/**",
      "lib/dnd-blocks/**",
      "lib/parsers/**",
      "app/dnd-editor/**",
      "app/modular-editor/**"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}